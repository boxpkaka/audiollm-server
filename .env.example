# =============================================================================
# AudioLLM Server — 环境变量
# 复制本文件为 .env 后按需修改。
#
# 运行参数(ASR / VAD / 情感 / 文本清洗 / ITN 与车牌规范化等)统一在根目录
# config.yaml 中配置(声明式单一入口)。本文件只放 config.yaml 用 ${ENV} 引用的
# 密钥与地址, 以及 start.sh 使用的端口/主机。
# =============================================================================

# 服务监听端口(start.sh 使用,默认 8443)。
PORT=8443

# 对外展示用的主机地址(start.sh 使用)。留空则自动探测本机 IP。
HOST_IP=

# 文本清洗 LLM(DashScope 兼容接口)的 API Key。
# 对应 config.yaml -> upstreams.dashscope_cleanup.api_key: ${DASHSCOPE_API_KEY}
DASHSCOPE_API_KEY=

# 热词抽取 LLM(取代旧 backend/api.json)。
# 对应 config.yaml -> upstreams.hotword_llm。base_url 为服务根(不含 /v1)。
HOTWORD_BASE_URL=
HOTWORD_MODEL=
HOTWORD_API_KEY=

# Triton 热词召回服务地址在 config.yaml -> upstreams.triton_recall 配置。
# 默认 http://localhost:10001 / rag_asr_retrieve, 不需要在 .env 中填写。
