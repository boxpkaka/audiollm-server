# =============================================================================
# AudioLLM Server — 环境变量
# 复制本文件为 .env 后按需修改。
#
# 本服务只消费下面这几个环境变量。ASR / VAD / 情感 / 文本清洗等运行参数
# 一律在 backend/config.json 中配置(配置单一入口),不再通过环境变量覆盖。
# =============================================================================

# 服务监听端口(start.sh 使用,默认 8443)。
PORT=8443

# 对外展示用的主机地址(start.sh 使用)。留空则自动探测本机 IP。
HOST_IP=

# 文本清洗 LLM 的 API Key。config.json 的 text_cleanup_api_key_env 指向的
# 环境变量名(默认 DASHSCOPE_API_KEY),运行时从这里读取,避免把密钥写进文件。
DASHSCOPE_API_KEY=
