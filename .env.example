# =============================================================================
# AudioLLM Server — Environment Variables
# Copy this file to .env and edit as needed.
# =============================================================================

# --- vLLM Server (Primary: Amphion) -----------------------------------------
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL_NAME=Amphion/Amphion-3B

# --- vLLM Server (Secondary: Qwen) ------------------------------------------
SECONDARY_VLLM_BASE_URL=http://localhost:8001
SECONDARY_VLLM_MODEL_NAME=Qwen/Qwen3-ASR-1.7B

# --- ASR Pipeline ------------------------------------------------------------
ENABLE_PRIMARY_ASR=1
ENABLE_SECONDARY_ASR=1
# Final-segment fusion. True keeps the historical dual-model behavior; set
# to 0 to skip the secondary call on final segments while still using it as
# a partial-stream noise gate. Auto-downgraded to 0 if secondary is off.
ENABLE_DUAL_ASR_FUSION=1
PRIMARY_ASR_TIMEOUT=4.0
ASR_REQUEST_TIMEOUT=120
DEBUG_SHOW_DUAL_ASR=1

# --- Pseudo-Streaming --------------------------------------------------------
ENABLE_PSEUDO_STREAM=1
PSEUDO_STREAM_INTERVAL_MS=500

# --- Dual-ASR Fusion ---------------------------------------------------------
FUSION_SIMILARITY_THRESHOLD=0.85
FUSION_MIN_PRIMARY_SCORE=0.55
FUSION_MAX_REPETITION_RATIO=0.35
FUSION_DISAGREEMENT_THRESHOLD=0.55
FUSION_HOTWORD_BOOST=0.12
FUSION_PRIMARY_SCORE_MARGIN=0.08

# --- VAD (Voice Activity Detection) ------------------------------------------
VAD_THRESHOLD=0.5
VAD_SMOOTHING_ALPHA=0.35
VAD_START_FRAMES=3
VAD_PRE_SPEECH_MS=500
VAD_END_FRAMES=
VAD_KEEP_TAIL_MS=40
SILENCE_DURATION_MS=200
MIN_SEGMENT_DURATION_MS=350

# --- Server -------------------------------------------------------------------
PORT=8443
